{
  "extends": "@vuepress/tsconfig/base.json",
  "compilerOptions": {
    "declaration": false,
    "lib": ["ES2023"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "target": "ES2023"
  },
  "include": ["./packages/**/*", "*.config.ts"],
  "exclude": ["**/node_modules/**", "**/dist/**"]
}
