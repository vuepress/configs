{
  "name": "@vuepress/oxfmt-config",
  "version": "8.1.0",
  "description": "Oxfmt config for VuePress Team",
  "homepage": "https://github.com/vuepress",
  "license": "MIT",
  "author": "meteorlxy <meteor.lxy@foxmail.com> (https://www.meteorlxy.cn)",
  "repository": {
    "type": "git",
    "url": "https://github.com/vuepress/configs.git"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "tsdown": "catalog:dev"
  },
  "peerDependencies": {
    "oxfmt": ">=0.42.0"
  }
}
